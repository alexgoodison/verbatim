# Verbatim / browser-use environment
# Copy to .env and fill in at least one key for the LLM.

# Browser Use Cloud (recommended for browser-use; sign up for API key)
# https://browser-use.com
BROWSER_USE_API_KEY=

# Alternative LLM providers (see browser-use supported models)
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
